    sny[i + 1] = sny[i] * cy1 + csy[i] * sy1;
    csy[i + 1] = csy[i] * cy1 - sny[i] * sy1;
  }
  d1 = 0;
  d2 = 0;
  for (i = 0; i < 7; i++)
    for (j = 0; j < 7; j++) {
      d1 = d1 + option.af[i][j] * snx[i] * sny[j] + option.bf[i][j] * csx[i] * csy[j];
      d2 = d2 + option.cf[i][j] * snx[i] * sny[j] - option.df[i][j] * csx[i] * csy[j];
